PORT=3000
MYSQL_HOST=localhost
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=barber_shop

# Gmail notification for the owner
EMAIL_FROM=your_email@gmail.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

# Google Calendar booking sync
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Set this to your deployed callback URL on Railway, or http://localhost:3000/api/google/oauth2callback for local testing.
GOOGLE_REDIRECT_URI=your_google_redirect_uri
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

SHOP_ADDRESS=Your Shop Address
SHOP_EMAIL=your_email@gmail.com
SHOP_NAME=Royal Barbershop 